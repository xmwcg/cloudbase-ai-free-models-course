/* 方式二：小程序聊天页样式（极简） */
.container { padding: 20rpx; }
.messages { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 20rpx; }
.msg { max-width: 80%; padding: 16rpx 20rpx; border-radius: 16rpx; font-size: 28rpx; line-height: 1.5; }
.msg.user { align-self: flex-end; background: #4d8dff; color: #fff; }
.msg.assistant { align-self: flex-start; background: #f2f3f5; color: #1a1a1a; }
.composer { display: flex; gap: 12rpx; align-items: center; }
.input { flex: 1; border: 1rpx solid #ddd; border-radius: 12rpx; padding: 12rpx 16rpx; font-size: 28rpx; }
